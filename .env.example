# === PostgreSQL (Langflow 내부 DB, compose 전용) ===
POSTGRES_USER=langflow
POSTGRES_PASSWORD=langflow
POSTGRES_DB=langflow

# === Langflow API Key (로컬 curl 테스트용) ===
# UI: Settings → API Keys 에서 본인 키 발급 후 .env 에만 입력 (팀 공유 금지)
# LANGFLOW_API_KEY=

# === Ollama (호스트 PC, Docker 밖) ===
# Langflow는 Docker 안에서 돌아감 → UI Ollama URL 은 host.docker.internal 사용
# Docker 연결 실패 시 Windows 사용자 환경변수:
#   OLLAMA_HOST=0.0.0.0:11434  (Ollama 트레이 앱 재시작 후)
# 점검: .\scripts\check-ollama-langflow.ps1
